__pycache__/
.pytest_cache/
*.pyc
.DS_Store
# large regenerable data + build artifacts
*.parquet
data/*.db
data/*.db-journal
*.db-journal
# raw per-row prediction caches (7.2 ablation store) -- summary JSON (the
# measured results) stays tracked, the underlying per-row cache doesn't
data/*_preds.pkl

# secrets (webhooks, API keys) live here — NEVER tracked
config.local.json
data/*.joblib

# test fixtures are small recorded samples, deliberately tracked
!nflvalue/sources/fixtures/*.parquet
# perm-test + db-backup debris (environment artifacts, never source)
data/__perm_*
data/*.db.bak_*
data/*.db-journal.bak_*
